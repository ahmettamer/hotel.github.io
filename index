      <div class="ok-msg" id="ok-msg" data-i18n="fOk"></div>
    </div>
  </section>

  <footer>
    <div class="f-logo">Four Mansions Hotel</div>
    <div class="f-sub" data-i18n="footerSub"></div>
    <div class="f-div"></div>
    <div class="f-info">Kayseri, Türkiye<br>info@fourmansionshotel.com</div>
  </footer>
</div>

<!-- ══════════════ MENU PAGE ══════════════ -->
<div class="page menu-page" id="page-menu">

  <div class="menu-hero">
    <div class="sec-label" data-i18n="menuHeroLabel"></div>
    <h2 class="sec-title" data-i18n="menuHeroTitle"></h2>
    <div class="sec-div"></div>
  </div>

  <!-- STICKY TABS -->
