/* ─── STATE ─── */
let lang = 'tr';

/* ─── PAGE SWITCH ─── */
function showPage(name) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-' + name).classList.add('active');
  document.querySelectorAll('.nav-links a').forEach(a => a.classList.remove('active'));
  document.getElementById('nl-' + name).classList.add('active');
  window.scrollTo({top:0,behavior:'smooth'});
}

/* ─── TAB SWITCH ─── */
function showTab(name, btn) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('on'));
  document.querySelectorAll('.tab').forEach(b => b.classList.remove('on'));
  document.getElementById('panel-' + name).classList.add('on');
  btn.classList.add('on');
}

/* ─── LANGUAGE ─── */
function toggleLang() {
  lang = lang === 'tr' ? 'en' : 'tr';
  document.getElementById('lang-btn').textContent = lang === 'tr' ? 'EN' : 'TR';
  document.documentElement.lang = lang;
  applyTranslations();
  renderAllMenus();
}

function applyTranslations() {
  const t = T[lang];
  document.querySelectorAll('[data-i18n]').forEach(el => {
    const key = el.dataset.i18n;
    if (t[key] !== undefined) el.textContent = t[key];
  });
  document.querySelectorAll('[data-i18n-ph]').forEach(el => {
    const key = el.dataset.i18nPh;
    if (t[key] !== undefined) el.placeholder = t[key];
  });
}

/* ─── RENDER MENUS ─── */
function renderAllMenus() {
  const panels = ['breakfast','dinner','civikli','hot','cold','dessert'];
  panels.forEach(key => renderPanel(key));
}

function renderPanel(key) {
  const items = MENU[key];
  const t = T[lang];
  const el = document.getElementById('panel-' + key);

  let html = '<div class="mgrid">';
  let lastCat = null;

  items.forEach(item => {
    if (item.cat && item.cat !== lastCat) {
      lastCat = item.cat;
      html += `<div class="cat-label">${t[item.cat] || item.cat}</div>`;
    }

    html += `
      <div class="mitem">
        <img class="mimg" src="${item.img}" alt="${item[lang].n}" loading="lazy"
             onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
        <div class="mimg-placeholder" style="display:none">🍽️</div>
        <div class="mbody">
          <div class="mhead">
            <span class="mname">${item[lang].n}</span>
            <span class="mprice">${item.price}</span>
          </div>
          <div class="mdesc">${item[lang].d}</div>
        </div>
      </div>`;
  });

  html += '</div>';
  el.innerHTML = html;
}

/* ─── STAR RATING ─── */
let stars = 0;
function setStar(v) {
  stars = v;
  document.querySelectorAll('.star').forEach((s,i) => s.classList.toggle('on', i < v));
}

/* ─── SUBMIT REVIEW ─── */
function submitReview() {
  const name = document.getElementById('rv-name').value.trim();
  const msg = document.getElementById('rv-msg').value.trim();
  if (!name || !msg) {
    alert(lang === 'tr' ? 'Lütfen adınızı ve yorumunuzu girin.' : 'Please fill in your name and review.');
    return;
  }
  document.querySelectorAll('.fg, .stars, .sub-btn').forEach(e => e.style.display = 'none');
  document.getElementById('ok-msg').style.display = 'block';
}

/* ─── INIT ─── */
applyTranslations();
renderAllMenus();
</script>
