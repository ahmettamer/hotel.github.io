        <div class="r-title" data-i18n="writeTitle"></div>
        <div class="r-desc" data-i18n="writeDesc"></div>
      </div>
    </div>

    <!-- FORM -->
    <div class="form-box" id="form-box">
      <h3 data-i18n="formTitle"></h3>
      <p data-i18n="formSub"></p>
      <div class="stars" id="stars">
        <span class="star" onclick="setStar(1)">★</span>
        <span class="star" onclick="setStar(2)">★</span>
        <span class="star" onclick="setStar(3)">★</span>
        <span class="star" onclick="setStar(4)">★</span>
        <span class="star" onclick="setStar(5)">★</span>
      </div>
      <div class="fg">
        <label data-i18n="fName"></label>
        <input type="text" id="rv-name" data-i18n-ph="fNamePh">
      </div>
      <div class="fg">
