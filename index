        <div class="r-title">TripAdvisor</div>
        <div class="r-desc" data-i18n="tripDesc"></div>
      </a>
      <a href="https://www.hotels.com" target="_blank" class="r-card">
        <span class="r-icon">⭐</span>
        <div class="r-title">Hotels.com</div>
        <div class="r-desc" data-i18n="hotelsDesc"></div>
