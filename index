      <button class="tab" onclick="showTab('dinner',this)" data-i18n="tabDinner"></button>
      <button class="tab" onclick="showTab('civikli',this)" data-i18n="tabCivikli"></button>
      <button class="tab" onclick="showTab('hot',this)" data-i18n="tabHot"></button>
      <button class="tab" onclick="showTab('cold',this)" data-i18n="tabCold"></button>
      <button class="tab" onclick="showTab('dessert',this)" data-i18n="tabDessert"></button>
    </div>
  </div>

  <!-- PANELS rendered by JS -->
  <div id="panel-breakfast" class="panel on"></div>
  <div id="panel-dinner" class="panel"></div>
  <div id="panel-civikli" class="panel"></div>
  <div id="panel-hot" class="panel"></div>
  <div id="panel-cold" class="panel"></div>
