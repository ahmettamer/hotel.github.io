<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Four Mansions Hotel — Kayseri</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Cinzel:wght@400;600&family=Lato:wght@300;400&display=swap" rel="stylesheet">
<style>
:root {
  --gold:#b89040;--gold-light:#d4aa5a;--gold-pale:#f5e8c5;
  --dark:#1a1410;--dark2:#251f18;--cream:#f9f3e8;--cream2:#f0e8d5;
  --text:#3a2e22;--text-light:#7a6a55;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{background:var(--dark);color:var(--text);font-family:'Lato',sans-serif;font-weight:300;overflow-x:hidden}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(26,20,16,0.97);backdrop-filter:blur(12px);border-bottom:1px solid rgba(184,144,64,0.3);display:flex;align-items:center;justify-content:space-between;padding:0 40px;height:68px}
.nav-logo{font-family:'Cinzel',serif;color:var(--gold);font-size:.9rem;letter-spacing:.35em;text-transform:uppercase}
.nav-right{display:flex;align-items:center;gap:28px}
.nav-links{display:flex;gap:28px;list-style:none}
.nav-links a{color:rgba(245,232,197,.75);text-decoration:none;font-size:.7rem;letter-spacing:.22em;text-transform:uppercase;transition:color .3s;padding:4px 0;border-bottom:1px solid transparent;transition:all .3s}
.nav-links a:hover,.nav-links a.active{color:var(--gold);border-bottom-color:var(--gold)}
.lang-btn{background:transparent;border:1px solid rgba(184,144,64,.45);color:var(--gold);padding:6px 14px;font-family:'Cinzel',serif;font-size:.6rem;letter-spacing:.25em;cursor:pointer;transition:all .3s}
.lang-btn:hover{background:var(--gold);color:var(--dark)}

/* PAGE SYSTEM */
.page{min-height:100vh;display:none}
.page.active{display:block}

/* ── REVIEW PAGE ── */
.review-page{background:var(--dark)}

.hero{min-height:100vh;background:var(--dark);position:relative;display:flex;align-items:center;justify-content:center;overflow:hidden;padding-top:68px}
.hero-bg{position:absolute;inset:0;background:radial-gradient(ellipse at 25% 55%,rgba(184,144,64,.09) 0%,transparent 60%),radial-gradient(ellipse at 75% 20%,rgba(184,144,64,.05) 0%,transparent 50%),linear-gradient(180deg,#1a1410 0%,#251f18 50%,#1a1410 100%)}
.hero-ornament{position:absolute;width:560px;height:560px;border:1px solid rgba(184,144,64,.1);border-radius:50%;top:50%;left:50%;transform:translate(-50%,-50%);animation:rot 45s linear infinite}
.hero-ornament::before{content:'';position:absolute;inset:34px;border:1px solid rgba(184,144,64,.05);border-radius:50%}
@keyframes rot{to{transform:translate(-50%,-50%) rotate(360deg)}}
.hero-content{position:relative;text-align:center;padding:20px;animation:fadeUp 1.1s ease both}
@keyframes fadeUp{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:translateY(0)}}
.hero-label{font-family:'Cinzel',serif;color:var(--gold);font-size:.6rem;letter-spacing:.55em;text-transform:uppercase;margin-bottom:22px;opacity:.8}
.hero-title{font-family:'Cormorant Garamond',serif;color:var(--gold-pale);font-size:clamp(3rem,8vw,6.5rem);font-weight:300;line-height:1.05;margin-bottom:8px}
.hero-title em{font-style:italic;color:var(--gold-light)}
.hero-sub{font-family:'Cinzel',serif;color:var(--gold);font-size:.65rem;letter-spacing:.6em;margin-bottom:44px;opacity:.7}
.hero-divider{width:80px;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);margin:0 auto 44px}
.hero-desc{color:rgba(245,232,197,.5);font-size:.88rem;letter-spacing:.04em;max-width:380px;margin:0 auto 44px;line-height:1.85}
.cta-group{display:flex;gap:14px;justify-content:center;flex-wrap:wrap}
.btn-gold{background:var(--gold);color:var(--dark);border:none;padding:13px 30px;font-family:'Cinzel',serif;font-size:.65rem;letter-spacing:.25em;cursor:pointer;transition:all .3s;text-decoration:none;display:inline-block}
.btn-gold:hover{background:var(--gold-light);transform:translateY(-2px)}
.btn-outline{background:transparent;color:var(--gold-pale);border:1px solid rgba(184,144,64,.45);padding:13px 30px;font-family:'Cinzel',serif;font-size:.65rem;letter-spacing:.25em;cursor:pointer;transition:all .3s;text-decoration:none;display:inline-block}
.btn-outline:hover{border-color:var(--gold);color:var(--gold);transform:translateY(-2px)}

/* SECTION COMMON */
.sec{padding:90px 40px}
.sec-label{font-family:'Cinzel',serif;font-size:.58rem;letter-spacing:.5em;text-transform:uppercase;color:var(--gold);margin-bottom:14px;text-align:center}
.sec-title{font-family:'Cormorant Garamond',serif;font-size:clamp(1.8rem,4vw,3rem);font-weight:300;text-align:center;margin-bottom:14px;color:var(--gold-pale)}
.sec-div{width:55px;height:1px;background:var(--gold);margin:0 auto 50px}

/* REVIEW CARDS */
.review-intro{text-align:center;color:rgba(245,232,197,.45);font-size:.85rem;max-width:480px;margin:-30px auto 50px;line-height:1.85}
.review-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:20px;max-width:960px;margin:0 auto 55px}
.r-card{border:1px solid rgba(184,144,64,.18);padding:34px 26px;text-align:center;cursor:pointer;transition:all .35s;position:relative;overflow:hidden;text-decoration:none;display:block;background:rgba(255,255,255,.02)}
.r-card::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(184,144,64,.07),transparent);opacity:0;transition:opacity .35s}
.r-card:hover{border-color:var(--gold);transform:translateY(-4px)}
.r-card:hover::before{opacity:1}
.r-icon{font-size:2.2rem;margin-bottom:14px;display:block}
.r-title{font-family:'Cinzel',serif;color:var(--gold);font-size:.7rem;letter-spacing:.2em;margin-bottom:8px}
.r-desc{color:rgba(245,232,197,.4);font-size:.77rem;line-height:1.7}

/* INTERNAL FORM */
.form-box{background:rgba(255,255,255,.03);border:1px solid rgba(184,144,64,.2);padding:40px;max-width:580px;margin:0 auto}
.form-box h3{font-family:'Cormorant Garamond',serif;color:var(--gold-pale);font-size:1.55rem;text-align:center;margin-bottom:6px}
.form-box p{color:rgba(245,232,197,.38);font-size:.78rem;text-align:center;margin-bottom:28px}
.fg{margin-bottom:18px}
.fg label{display:block;font-family:'Cinzel',serif;font-size:.58rem;letter-spacing:.3em;color:var(--gold);margin-bottom:7px}
.fg input,.fg textarea,.fg select{width:100%;background:rgba(255,255,255,.04);border:1px solid rgba(184,144,64,.2);color:var(--gold-pale);padding:11px 15px;font-family:'Lato',sans-serif;font-size:.83rem;outline:none;transition:border-color .3s}
.fg input:focus,.fg textarea:focus{border-color:var(--gold)}
.fg textarea{height:95px;resize:vertical}
.stars{display:flex;gap:7px;font-size:1.45rem;margin-bottom:18px;cursor:pointer}
.star{color:rgba(184,144,64,.3);transition:color .2s}
.star.on{color:var(--gold)}
.sub-btn{width:100%;background:var(--gold);color:var(--dark);border:none;padding:15px;font-family:'Cinzel',serif;font-size:.65rem;letter-spacing:.3em;cursor:pointer;transition:all .3s;margin-top:6px}
.sub-btn:hover{background:var(--gold-light)}
.ok-msg{display:none;text-align:center;color:var(--gold-light);font-family:'Cormorant Garamond',serif;font-size:1.2rem;padding:18px}

/* ── MENU PAGE ── */
.menu-page{background:var(--dark2)}

.menu-hero{background:var(--dark);padding:120px 40px 60px;text-align:center;position:relative;overflow:hidden}
.menu-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 100%,rgba(184,144,64,.07) 0%,transparent 65%)}

/* TABS */
.tabs-wrap{position:sticky;top:68px;z-index:50;background:rgba(26,20,16,.97);backdrop-filter:blur(10px);border-bottom:1px solid rgba(184,144,64,.2);padding:0 20px}
.tabs{display:flex;justify-content:center;gap:2px;overflow-x:auto;scrollbar-width:none;padding:12px 0}
.tabs::-webkit-scrollbar{display:none}
.tab{background:transparent;border:1px solid rgba(184,144,64,.15);color:rgba(245,232,197,.45);padding:9px 20px;font-family:'Cinzel',serif;font-size:.6rem;letter-spacing:.2em;cursor:pointer;transition:all .3s;white-space:nowrap}
.tab.on,.tab:hover{background:var(--gold);color:var(--dark);border-color:var(--gold)}

/* MENU PANELS */
.panel{display:none;padding:50px 40px}
.panel.on{display:block}
.cat-label{font-family:'Cinzel',serif;color:var(--gold);font-size:.58rem;letter-spacing:.45em;text-transform:uppercase;text-align:center;padding:36px 0 18px;border-top:1px solid rgba(184,144,64,.12);margin-top:10px;grid-column:1/-1}
.cat-label:first-child{border-top:none;padding-top:0}

/* MENU GRID */
.mgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:2px;max-width:1140px;margin:0 auto}
.mitem{background:rgba(255,255,255,.025);border:1px solid rgba(184,144,64,.08);transition:all .3s;overflow:hidden}
.mitem:hover{background:rgba(184,144,64,.06);border-color:rgba(184,144,64,.3);transform:translateY(-2px)}
.mimg{width:100%;height:185px;object-fit:cover;display:block;background:rgba(184,144,64,.06)}
.mimg-placeholder{width:100%;height:185px;display:flex;align-items:center;justify-content:center;font-size:2.5rem;background:linear-gradient(135deg,rgba(184,144,64,.08),rgba(184,144,64,.03))}
.mbody{padding:22px}
.mhead{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px;gap:10px}
.mname{font-family:'Cormorant Garamond',serif;color:var(--gold-pale);font-size:1.05rem;font-weight:400;line-height:1.3}
.mprice{font-family:'Cinzel',serif;color:var(--gold);font-size:.72rem;white-space:nowrap;letter-spacing:.05em}
.mdesc{color:rgba(245,232,197,.38);font-size:.76rem;line-height:1.7}

/* FOOTER */
footer{background:var(--dark);border-top:1px solid rgba(184,144,64,.18);padding:55px 40px;text-align:center}
.f-logo{font-family:'Cinzel',serif;color:var(--gold);font-size:1.1rem;letter-spacing:.4em;margin-bottom:6px}
.f-sub{font-family:'Cormorant Garamond',serif;color:rgba(245,232,197,.28);font-size:.88rem;font-style:italic;margin-bottom:28px}
.f-div{width:38px;height:1px;background:var(--gold);margin:0 auto 20px;opacity:.4}
.f-info{color:rgba(245,232,197,.22);font-size:.72rem;letter-spacing:.1em;line-height:2}

@media(max-width:640px){
  nav{padding:0 18px}
  .nav-links{gap:14px}
  .sec,.panel{padding:60px 18px}
  .form-box{padding:26px 18px}
  .hero-ornament{width:300px;height:300px}
}
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-logo">Four Mansions Hotel</div>
  <div class="nav-right">
    <ul class="nav-links">
      <li><a href="#" onclick="showPage('review');return false" id="nl-review" class="active" data-i18n="navReview"></a></li>
      <li><a href="#" onclick="showPage('menu');return false" id="nl-menu" data-i18n="navMenu"></a></li>
    </ul>
    <button class="lang-btn" onclick="toggleLang()" id="lang-btn">EN</button>
  </div>
</nav>

<!-- ══════════════ REVIEW PAGE ══════════════ -->
